# =============================================================================
# QONFORME — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# =============================================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER_MONTHLY=price_starter_monthly
STRIPE_PRICE_STARTER_YEARLY=price_starter_yearly
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly
STRIPE_PRICE_PRO_YEARLY=price_pro_yearly

# --- Resend (emails transactionnels) ---
RESEND_API_KEY=re_...
# OBLIGATOIRE : adresse d'envoi depuis un domaine vérifié sur resend.com/domains
# Sans cette variable, les emails échouent silencieusement pour les adresses non vérifiées
RESEND_FROM_EMAIL=noreply@qonforme.fr
# Optionnel : redirige TOUS les emails vers cette adresse (mode sandbox de test)
# Supprimer cette ligne en production
# RESEND_TEST_EMAIL=test@example.com

# --- PPF / Chorus Pro (Portail Public de Facturation) ---
PPF_API_URL=https://sandbox.api.chorus-pro.gouv.fr
PPF_CLIENT_ID=
PPF_CLIENT_SECRET=

# --- INSEE Sirene (recherche SIREN) ---
INSEE_API_KEY=

# --- Application ---
NEXT_PUBLIC_APP_URL=https://qonforme.fr

# --- Admin ---
# Credentials de connexion à l'espace admin (/admin/login)
# Totalement indépendant des comptes utilisateurs Supabase
ADMIN_EMAIL=admin@qonforme.fr
ADMIN_PASSWORD=mot-de-passe-tres-securise
# Secret pour signer le cookie de session (min. 32 caractères aléatoires)
ADMIN_COOKIE_SECRET=changez-moi-avec-32-caracteres-aleatoires-minimum
